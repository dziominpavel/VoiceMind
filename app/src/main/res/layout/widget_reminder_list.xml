<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@android:color/transparent"
    android:padding="6dp">

    <!-- Левая часть: 3 строки напоминаний -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical">

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/row_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="1dp">

            <TextView
                android:id="@+id/body_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/time_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textSize="10sp"
                android:textColor="#B3FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end" />

            <ImageView
                android:id="@+id/checkbox_1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Toggle done" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/row_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="1dp">

            <TextView
                android:id="@+id/body_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/time_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textSize="10sp"
                android:textColor="#B3FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end" />

            <ImageView
                android:id="@+id/checkbox_2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Toggle done" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:id="@+id/row_3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="1dp">

            <TextView
                android:id="@+id/body_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/time_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:textSize="10sp"
                android:textColor="#B3FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end" />

            <ImageView
                android:id="@+id/checkbox_3"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Toggle done" />
        </LinearLayout>

    </LinearLayout>

    <!-- Правая часть: микрофон (кликабельная область большая, визуально меньше) -->
    <FrameLayout
        android:id="@+id/mic_area"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="4dp"
        android:padding="12dp"
        android:background="@android:color/transparent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_mic_background">

            <ImageView
                android:id="@+id/mic_button"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic"
                android:tint="#FFFFFF"
                android:contentDescription="@string/home_mic_start" />
        </FrameLayout>
    </FrameLayout>

</LinearLayout>
